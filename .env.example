# ── Supabase ─────────────────────────────────────────────────
# For local dev: values are printed by `npx supabase start`
# For production: copy from Supabase project settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Anon key (public, safe to commit in js/config.js):
SUPABASE_ANON_KEY=your_anon_public_key_here

# ── Batch scripts ─────────────────────────────────────────────
PROJECT_ID=your_project_uuid_here
DEFAULT_PARTICIPANT_PASSWORD=ChangeMe2026!
TEST_USER_PASSWORD=ChangeMe2026!

# ── Edge function secrets ─────────────────────────────────────
# Set via `npx supabase secrets set` — not read from .env by functions
# Listed here as a reference for what needs to be configured.
# N8N_WEBHOOK_URL=https://your-n8n-host/webhook/...
# N8N_PROJECT_UPDATE_WEBHOOK_URL=https://your-n8n-host/webhook/...
# TRACKER_BASE_URL=https://your-app-domain.com
# PROJECT_UPDATE_CRON_SECRET=replace_with_a_long_random_secret
